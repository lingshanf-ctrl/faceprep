generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // Vercel Postgres
}

// 用户
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   // 密码（已哈希）
  avatar    String?
  plan      Plan     @default(FREE)
  isAdmin   Boolean  @default(false)  // 管理员标识
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practices           Practice[]
  favorites           Favorite[]
  customQuestions     CustomQuestion[]
  aiGeneratedQuestions AIGeneratedQuestion[]
  sessions            InterviewSession[]
  memberships         MembershipOrder[]
  usageRecords        UsageRecord[]
}

enum Plan {
  FREE
  PRO
}

// 会员类型
enum MembershipType {
  CREDIT   // 次卡
  MONTHLY  // 月卡
}

// 订单状态
enum OrderStatus {
  ACTIVE     // 有效
  EXPIRED    // 已过期
  CONSUMED   // 已用完
  CANCELLED  // 已取消
}

// 消费来源类型
enum UsageSourceType {
  PRACTICE          // 单题练习
  INTERVIEW_SESSION // 模拟面试
}

// 面试题
model Question {
  id              String   @id @default(cuid())
  title           String   // 问题
  category        Category // 岗位分类
  type            QuestionType // 题目类型
  difficulty      Int      @default(1) // 难度 1-3
  frequency       Int      @default(1) // 高频度 1-3
  keyPoints       String   // 考察点
  framework       String?  // 回答框架
  referenceAnswer String   // 参考答案
  commonMistakes  String?  // 常见错误
  tips            String?  // 小贴士
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  practices Practice[]
  favorites Favorite[]
}

enum Category {
  FRONTEND   // 前端
  BACKEND    // 后端
  PRODUCT    // 产品
  DESIGN     // 设计
  OPERATION  // 运营
  GENERAL    // 通用
}

enum QuestionType {
  INTRO      // 自我介绍
  PROJECT    // 项目经历
  TECHNICAL  // 技术题
  BEHAVIORAL // 行为题
  HR         // HR题
}

// 练习记录
model Practice {
  id        String   @id @default(cuid())
  userId    String
  questionId String?
  answer    String   // 用户回答
  score     Int?     // AI 评分 0-100
  feedback  String?  // AI 点评(JSON字符串，包含good/improve/suggestion/starAnswer)
  duration  Int?     // 答题时长(秒)

  // 题目快照（练习时的状态，防止题目被修改或删除后丢失上下文）
  questionTitle    String? // 当时的题目标题
  questionCategory Category? // 当时的题目分类
  questionType     QuestionType? // 当时的题目类型
  questionDifficulty Int?   // 当时的题目难度

  // AI 评估状态追踪（异步评估支持）
  evaluationStatus      EvaluationStatus @default(COMPLETED) // PENDING, PROCESSING, COMPLETED, FAILED
  evaluationError       String?          // 错误信息
  evaluationRetries     Int              @default(0) // 重试次数
  evaluationStartedAt   DateTime?        // 评估开始时间
  evaluationCompletedAt DateTime?        // 评估完成时间

  // AI 生成题目关联
  aiGeneratedQuestionId String?

  createdAt DateTime @default(now())

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  question           Question?           @relation(fields: [questionId], references: [id], onDelete: SetNull)
  aiGeneratedQuestion AIGeneratedQuestion? @relation(fields: [aiGeneratedQuestionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([questionId])
  @@index([evaluationStatus])
  @@index([aiGeneratedQuestionId])
}

// 收藏
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
}

// 自定义题目（用户专属题库）
model CustomQuestion {
  id              String       @id @default(cuid())
  userId          String
  title           String
  category        Category
  type            QuestionType
  difficulty      Int          @default(1)
  keyPoints       String?
  referenceAnswer String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// AI 生成题目（用户专属面试间）
model AIGeneratedQuestion {
  id              String       @id @default(cuid())
  userId          String
  title           String       // 题目内容
  type            QuestionType // 题目类型
  difficulty      String       // 难度 easy/medium/hard
  keyPoints       String       // 考察点

  // 生成上下文
  jdText          String?      @db.Text // JD 原文
  resumeText      String?      @db.Text // 简历原文
  generationMode  String       @default("ai") // ai 或 rule

  // 关联练习记录
  practices       Practice[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// 面试会话
model InterviewSession {
  id          String   @id @default(cuid())
  userId      String
  title       String   // 面试标题
  jdText      String?  @db.Text // JD 原文
  resumeText  String?  @db.Text // 简历原文

  // 岗位信息
  jobCompany  String?  // 公司名称
  jobPosition String?  // 职位名称
  jobLevel    String?  // 职级 junior/mid/senior

  // 面试状态
  status      InterviewStatus @default(PENDING)

  // 题目快照 (JSON 数组)
  questions   String?  @db.Text // JSON: InterviewQuestion[]

  // 面试结果
  overallScore     Int      @default(0)     // 总分 0-100
  dimensionScores  String?  // JSON: { technical, behavioral, project, communication }
  overallFeedback  String?  @db.Text        // 整体反馈
  strengths        String?  @db.Text        // JSON: string[]
  improvements     String?  @db.Text        // JSON: string[]
  nextSteps        String?  @db.Text        // JSON: string[]

  // AI 深度评价 (JSON)
  aiEvaluation     String?  @db.Text        // JSON: AIOverallEvaluation

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers  InterviewAnswer[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum InterviewStatus {
  PENDING     // 待开始
  IN_PROGRESS // 进行中
  COMPLETED   // 已完成
  ABANDONED   // 已放弃
}

// 单题评估状态
enum EvaluationStatus {
  PENDING     // 等待评估
  PROCESSING  // 评估中
  COMPLETED   // 评估完成
  FAILED      // 评估失败
}

// 面试答题记录
model InterviewAnswer {
  id            String  @id @default(cuid())
  sessionId     String
  questionId    String  // 题目ID
  questionTitle String  // 题目标题（快照）
  questionType  String? // 题目类型
  questionDifficulty String? // 题目难度
  questionKeyPoints String? @db.Text // 考察点

  answer        String? @db.Text // 用户回答
  score         Int     @default(0) // AI评分
  feedback      String? @db.Text // JSON: { good, improve, suggestion, dimensions, improvements, optimizedAnswer }

  orderIndex    Int     // 答题顺序
  duration      Int     @default(0) // 答题时长（秒）

  startedAt     DateTime @default(now())
  completedAt   DateTime?

  // AI 评估状态追踪
  evaluationStatus      EvaluationStatus @default(PENDING)
  evaluationError       String?          // 错误信息
  evaluationRetries     Int              @default(0) // 重试次数
  evaluationStartedAt   DateTime?        // 评估开始时间
  evaluationCompletedAt DateTime?        // 评估完成时间

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([orderIndex])
  @@index([evaluationStatus])
}

// 啄木鸟反馈（Bug/建议）
model BugReport {
  id          String   @id @default(cuid())
  type        BugType  @default(BUG)
  content     String   // 反馈内容
  pageUrl     String   // 当前页面URL
  userAgent   String   // 用户浏览器信息
  status      BugStatus @default(OPEN)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum BugType {
  BUG     // Bug
  FEATURE // 功能建议
  OTHER   // 其他
}

enum BugStatus {
  OPEN      // 待处理
  IN_PROGRESS // 处理中
  RESOLVED  // 已解决
  CLOSED    // 已关闭
}

// 会员订单（次卡/月卡）
model MembershipOrder {
  id            String         @id @default(cuid())
  userId        String
  type          MembershipType
  status        OrderStatus    @default(ACTIVE)

  // 次卡字段
  totalCredits  Int?           // 总次数
  usedCredits   Int            @default(0) // 已使用次数

  // 月卡字段
  startDate     DateTime?      // 生效日期
  endDate       DateTime?      // 到期日期

  // 管理字段
  note          String?        // 备注
  createdBy     String         // 开通人（admin ID 或 "system"）
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageRecords  UsageRecord[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([endDate])
}

// 消费记录
model UsageRecord {
  id              String          @id @default(cuid())
  userId          String
  membershipId    String          // 关联的会员订单
  sourceType      UsageSourceType // 消费来源类型
  sourceId        String          // Practice ID 或 InterviewSession ID
  sourceTitle     String?         // 题目/面试标题（冗余存储便于展示）
  createdAt       DateTime        @default(now())

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership      MembershipOrder @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId]) // 防止重复扣费
  @@index([userId])
  @@index([membershipId])
  @@index([createdAt])
}
