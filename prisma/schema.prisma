generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   // 密码（已哈希）
  avatar    String?
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practices       Practice[]
  favorites       Favorite[]
  customQuestions CustomQuestion[]
  sessions        InterviewSession[]
}

enum Plan {
  FREE
  PRO
}

// 面试题
model Question {
  id              String   @id @default(cuid())
  title           String   // 问题
  category        Category // 岗位分类
  type            QuestionType // 题目类型
  difficulty      Int      @default(1) // 难度 1-3
  frequency       Int      @default(1) // 高频度 1-3
  keyPoints       String   // 考察点
  framework       String?  // 回答框架
  referenceAnswer String   // 参考答案
  commonMistakes  String?  // 常见错误
  tips            String?  // 小贴士
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  practices Practice[]
  favorites Favorite[]
}

enum Category {
  FRONTEND   // 前端
  BACKEND    // 后端
  PRODUCT    // 产品
  DESIGN     // 设计
  OPERATION  // 运营
  GENERAL    // 通用
}

enum QuestionType {
  INTRO      // 自我介绍
  PROJECT    // 项目经历
  TECHNICAL  // 技术题
  BEHAVIORAL // 行为题
  HR         // HR题
}

// 练习记录
model Practice {
  id        String   @id @default(cuid())
  userId    String
  questionId String?
  answer    String   // 用户回答
  score     Int?     // AI 评分 0-100
  feedback  String?  // AI 点评(JSON字符串，包含good/improve/suggestion/starAnswer)
  duration  Int?     // 答题时长(秒)

  // 题目快照（练习时的状态，防止题目被修改或删除后丢失上下文）
  questionTitle    String? // 当时的题目标题
  questionCategory Category? // 当时的题目分类
  questionType     QuestionType? // 当时的题目类型
  questionDifficulty Int?   // 当时的题目难度

  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question? @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([questionId])
}

// 收藏
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
}

// 自定义题目（用户专属题库）
model CustomQuestion {
  id              String       @id @default(cuid())
  userId          String
  title           String
  category        Category
  type            QuestionType
  difficulty      Int          @default(1)
  keyPoints       String?
  referenceAnswer String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 面试会话
model InterviewSession {
  id          String   @id @default(cuid())
  userId      String
  title       String // 面试标题
  description String? // 岗位描述
  status      InterviewStatus @default(IN_PROGRESS)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers  InterviewAnswer[]

  @@index([userId])
  @@index([status])
}

enum InterviewStatus {
  IN_PROGRESS // 进行中
  COMPLETED   // 已完成
  ABANDONED   // 已放弃
}

// 面试答题记录
model InterviewAnswer {
  id        String  @id @default(cuid())
  sessionId String
  questionId String // 题目ID（可能是系统题或自定义题）
  questionTitle String // 题目标题（快照）
  answer    String? // 用户回答
  score     Int?    // AI评分
  feedback  String? // AI反馈
  order     Int     // 答题顺序
  duration  Int?    // 答题时长（秒）
  createdAt DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([order])
}

// 啄木鸟反馈（Bug/建议）
model BugReport {
  id          String   @id @default(cuid())
  type        BugType  @default(BUG)
  content     String   // 反馈内容
  pageUrl     String   // 当前页面URL
  userAgent   String   // 用户浏览器信息
  status      BugStatus @default(OPEN)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum BugType {
  BUG     // Bug
  FEATURE // 功能建议
  OTHER   // 其他
}

enum BugStatus {
  OPEN      // 待处理
  IN_PROGRESS // 处理中
  RESOLVED  // 已解决
  CLOSED    // 已关闭
}
