# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# AI Provider (deepseek / openai / qwen)
AI_PROVIDER="deepseek"

# DeepSeek API (推荐，国内稳定，便宜)
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY="your-deepseek-api-key"

# OpenAI API (可选)
# OPENAI_API_KEY="your-openai-api-key"

# 通义千问 API (可选)
# 申请地址: https://dashscope.console.aliyun.com/
# QWEN_API_KEY="your-qwen-api-key"

# Kimi API (用于付费用户深度分析)
# 申请地址: https://platform.moonshot.cn/
# KIMI_API_KEY="your-kimi-api-key"

# NextAuth 配置（生产环境必须配置）
# ⚠️ NEXTAUTH_URL 是必需的，否则会报 configuration 错误
# 本地开发: http://localhost:3000
# 生产环境: https://your-domain.com
NEXTAUTH_URL="https://your-domain.com"

# AUTH_SECRET 必须是随机生成的安全密钥
# 生成方法: openssl rand -base64 32
# 或在线生成: https://generate-secret.vercel.app/32
AUTH_SECRET="your-auth-secret-key-min-32-characters"

# WeChat OAuth (微信开放平台 - 网站应用)
# 申请地址: https://open.weixin.qq.com/
# 1. 注册开放平台账号
# 2. 创建网站应用并通过审核
# 3. 获取 AppID 和 AppSecret
# 4. 配置授权回调域: your-domain.com/api/auth/callback/wechat
WECHAT_APP_ID="your-wechat-app-id"
WECHAT_APP_SECRET="your-wechat-app-secret"

# Node 环境（production / development）
NODE_ENV="production"

# JWT Secret（生产环境必须配置，用于用户认证）
# ⚠️ 非常重要：如果泄露，攻击者可以伪造任意用户会话
# 生成方法: openssl rand -base64 32
# 必须设置，不设置应用会无法启动
JWT_SECRET=""

# 管理员看板密钥（访问 /admin 需要）
# 建议用随机字符串，比如: openssl rand -base64 32
ADMIN_TOKEN="your-admin-secret-token"

# 邮件服务配置（可选）
# 如果不配置，开发环境会使用模拟模式（在控制台打印链接）
# 生产环境推荐：Resend (https://resend.com) 或 SendGrid
#
# Resend 配置示例：
# EMAIL_HOST="smtp.resend.com"
# EMAIL_PORT="587"
# EMAIL_USER="resend"
# EMAIL_PASS="your-resend-api-key"
# EMAIL_FROM="noreply@yourdomain.com"
#
# Gmail 配置示例（需要应用专用密码）：
# EMAIL_HOST="smtp.gmail.com"
# EMAIL_PORT="587"
# EMAIL_USER="your-email@gmail.com"
# EMAIL_PASS="your-app-password"
# EMAIL_FROM="your-email@gmail.com"
